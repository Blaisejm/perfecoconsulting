---
const year = new Date().getFullYear();
---

<footer class="bg-navy-dark text-white">
  <!-- CTA Band -->
  <div class="py-12 px-4" style="background: linear-gradient(135deg, #1A3A7A 0%, #2E5DB3 100%);">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">
        Vous souhaitez reprendre le contrôle&nbsp;?
      </h2>
      <p class="text-white/85 mb-6 text-lg">
        En 60 minutes, vous repartez avec une lecture claire de votre organisation et 2 à 3 pistes d'amélioration concrètes.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-teal hover:bg-teal-light text-white font-black px-8 py-4 rounded-xl transition-colors shadow-lg uppercase tracking-wide"
      >
        Demander un diagnostic stratégique
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      <p class="text-white/70 text-sm mt-3">Échange confidentiel · Réponse sous 48h · Mené par l'équipe PerfEco</p>
    </div>
  </div>

  <!-- Footer links -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="mb-3">
          <img src="/logo-perfeco.svg" alt="PerfEco Consulting" class="h-10 w-auto brightness-0 invert" />
        </div>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs">
          Simplifier l'organisation, fiabiliser le pilotage et redonner aux dirigeants du temps utile pour décider.
        </p>
        <div class="mt-4 flex gap-4">
          <a href="https://www.linkedin.com/company/perfecoconsulting" target="_blank" rel="noopener" class="text-gray-400 hover:text-teal transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-4">Navigation</h3>
        <ul class="space-y-2">
          {[
            ['/', 'Accueil'],
            ['/approche', 'Notre approche'],
            ['/solutions', 'Nos solutions'],
            ['/secteurs', 'Secteurs'],
            ['/resultats', 'Résultats clients'],
            ['/ressources', 'Ressources'],
            ['/a-propos', 'À propos'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="text-gray-400 hover:text-white text-sm transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-4">Contact</h3>
        <ul class="space-y-3 text-sm text-gray-400">
          <li>
            <a href="mailto:contact@perfeco.nc" class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              contact@perfeco.nc
            </a>
          </li>
          <li>
            <a href="tel:+68773087" class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              +687 73 08 75
            </a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Nouvelle-Calédonie<br />& Polynésie française</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-gray-500">
      <p>© {year} PerfEco Consulting. Tous droits réservés.</p>
      <div class="flex gap-4">
        <a href="/mentions-legales" class="hover:text-gray-300 transition-colors">Mentions légales</a>
        <a href="/en/legal" class="hover:text-gray-300 transition-colors">Legal Notice</a>
      </div>
    </div>
  </div>
</footer>
