---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Articles de blog — à terme géré via CMS Decap
const articles = [
  {
    slug: 'une-strategie-ne-suffit-pas',
    titre: 'Une stratégie ne suffit pas : l\'exécution comme avantage concurrentiel',
    date: '2026-07-08',
    categorie: 'Exécution',
    extrait: '40 % de la valeur stratégique est perdue à l\'étape de l\'exécution (HBR). Les organisations "saines" sont 3× plus performantes sur le long terme (McKinsey). Les 4 piliers de l\'exécution rigoureuse.',
    serie: 'Exécution Stratégique · 2/8',
  },
  {
    slug: 'plans-strategiques-execution',
    titre: 'Pourquoi les plans stratégiques n\'aboutissent pas — alors que la stratégie est souvent la bonne',
    date: '2026-07-01',
    categorie: 'Stratégie',
    extrait: 'Une stratégie solide ne suffit pas. L\'exécution est la compétence rare et décisive. Symptômes, causes et 4 leviers pour rapprocher stratégie et résultats concrets dans votre organisation.',
    serie: 'Exécution Stratégique · 1/8',
  },
  {
    slug: 'qualification-dossier-escalade-management',
    titre: 'Un dossier est-il encore standard ? Les 3 critères que tout manager doit maîtriser',
    date: '2026-06-23',
    categorie: 'Gouvernance',
    extrait: 'Un dossier cesse d\'être standard dès qu\'il dépasse le cadre habituel en complexité, en montant ou en risque. Trois critères simples pour éviter les erreurs de qualification.',
  },
  {
    slug: 'volatilite-geopolitique-avantage-comex',
    titre: 'Volatilité géopolitique : 5 leviers pour en faire un avantage compétitif',
    date: '2026-06-18',
    categorie: 'Pilotage',
    extrait: 'L\'instabilité est devenue structurelle. Comment les COMEX peuvent transformer cette contrainte en avantage ? Lecture PerfEco d\'un article McKinsey Quarterly.',
  },
];
---

<Base title="Ressources & Articles � Performance organisationnelle NC" description="Blog PerfEco : articles et guides pratiques sur la performance organisationnelle, le pilotage dirigeant et la transformation digitale en Nouvelle-Calédonie.">
  <Nav />
  <main class="pt-16">

    <section class="bg-navy-dark text-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">Ressources</p>
        <h1 class="text-4xl sm:text-5xl font-bold mb-6">Insights pour dirigeants</h1>
        <p class="text-gray-300 text-lg">Articles pratiques sur la performance organisationnelle, le pilotage et la transformation — dans le contexte NC & Pacifique.</p>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto">

        <div class="space-y-8">
          {articles.map(article => (
            <article class="bg-white border border-gray-100 rounded-xl shadow-sm p-8 flex flex-col sm:flex-row gap-6">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xs bg-teal/10 text-teal font-medium px-2 py-0.5 rounded-full">{article.categorie}</span>
                  <time class="text-xs text-gray-400">{new Date(article.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                </div>
                <h2 class="text-xl font-bold text-navy mb-3 leading-snug">{article.titre}</h2>
                <p class="text-gray-600 text-sm leading-relaxed mb-4">{article.extrait}</p>
                <a href={`/ressources/${article.slug}`} class="text-teal font-semibold text-sm hover:underline inline-flex items-center gap-1">
                  Lire l'article →
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-14 bg-gray-50 rounded-xl p-8 text-center">
          <h2 class="text-xl font-bold text-navy mb-3">Recevoir les prochains articles</h2>
          <p class="text-gray-600 text-sm mb-6">Analyses et guides pratiques sur la performance dirigeante en NC & Polynésie — sans jargon, directement actionnables.</p>
          <form name="newsletter" method="POST" data-netlify="true" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input type="hidden" name="form-name" value="newsletter" />
            <input type="email" name="email" required placeholder="votre@email.nc" class="flex-1 border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal" />
            <button type="submit" class="bg-teal hover:bg-teal-dark text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors">
              S'inscrire
            </button>
          </form>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Base>
