---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Our Approach — PerfEco Consulting" description="PerfEco starts from how your organisation really works — not from a theoretical model. Discover our 4-pillar method.">
  <Nav />
  <main class="pt-16">

    <section class="bg-navy-dark text-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">Our approach</p>
        <h1 class="text-4xl sm:text-5xl font-bold mb-6">
          We start from how your organisation really works —<br />
          <span class="text-gray-400 font-normal">not from a pre-written solution.</span>
        </h1>
        <p class="text-gray-300 text-lg leading-relaxed">
          Before the first meeting, we already analyse visible signals: organisational chart, reporting lines, contract types on key positions. We arrive with hypotheses — not generic questions.
        </p>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid sm:grid-cols-3 gap-10 mb-20">
          <div>
            <div class="text-5xl font-bold text-teal/20 mb-3">01</div>
            <h3 class="text-lg font-bold text-navy mb-3">See clearly — lucidity</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Objective reading of how the organisation really works. Internal proximity filters reality. We make visible what you can no longer see from inside.</p>
          </div>
          <div>
            <div class="text-5xl font-bold text-teal/20 mb-3">02</div>
            <h3 class="text-lg font-bold text-navy mb-3">Decide — legitimacy</h3>
            <p class="text-gray-600 text-sm leading-relaxed">A neutral basis for arbitrating changes and making them understandable to teams. No out-of-touch recommendations.</p>
          </div>
          <div>
            <div class="text-5xl font-bold text-teal/20 mb-3">03</div>
            <h3 class="text-lg font-bold text-navy mb-3">Execute — action</h3>
            <p class="text-gray-600 text-sm leading-relaxed">A concrete, actionable plan. The goal is not a report — it is visible, measurable change, grounded in your reality.</p>
          </div>
        </div>

        <h2 class="text-3xl font-bold text-navy text-center mb-10">4 pillars calibrated to your real constraints</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="border border-gray-100 rounded-xl p-6 shadow-sm">
            <div class="text-teal font-bold text-xs mb-2">Pillar 01</div>
            <h3 class="font-bold text-navy text-lg mb-3">Stronger financial visibility</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Reliable reporting, controlled cash flow, secured margins. Decisions based on facts, not intuitions.</p>
          </div>
          <div class="border border-gray-100 rounded-xl p-6 shadow-sm">
            <div class="text-teal font-bold text-xs mb-2">Pillar 02</div>
            <h3 class="font-bold text-navy text-lg mb-3">Organisational simplification</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Clarification of roles, responsibilities and management lines. Smoother cross-functional processes.</p>
          </div>
          <div class="border border-gray-100 rounded-xl p-6 shadow-sm">
            <div class="text-teal font-bold text-xs mb-2">Pillar 03</div>
            <h3 class="font-bold text-navy text-lg mb-3">Pragmatic digitalisation</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Targeted automation, tools adapted to the territory. Technology in service of the organisation — not the other way around.</p>
          </div>
          <div class="border border-gray-100 rounded-xl p-6 shadow-sm">
            <div class="text-teal font-bold text-xs mb-2">Pillar 04</div>
            <h3 class="font-bold text-navy text-lg mb-3">Indicator-driven management</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Concrete KPIs, regular monitoring, objectified and measurable results at every stage of the assignment.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4 bg-gray-50">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-navy mb-12">Intervention sequence</h2>
        <div class="grid sm:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 shadow-sm text-left">
            <div class="text-xs font-bold text-teal uppercase tracking-wide mb-1">Phase 1</div>
            <div class="text-xl font-bold text-navy mb-1">Targeted review</div>
            <div class="text-sm text-gray-400 mb-4">4 weeks</div>
            <p class="text-gray-600 text-sm leading-relaxed">Analysis of real operations. Identification of priority blockers. Field-validated hypotheses.</p>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm text-left">
            <div class="text-xs font-bold text-teal uppercase tracking-wide mb-1">Phase 2</div>
            <div class="text-xl font-bold text-navy mb-1">Structuring</div>
            <div class="text-sm text-gray-400 mb-4">3 months</div>
            <p class="text-gray-600 text-sm leading-relaxed">Implementation of recommendations. Clarification of processes. Installation of management indicators.</p>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm text-left">
            <div class="text-xs font-bold text-teal uppercase tracking-wide mb-1">Phase 3</div>
            <div class="text-xl font-bold text-navy mb-1">Support</div>
            <div class="text-sm text-gray-400 mb-4">6 months</div>
            <p class="text-gray-600 text-sm leading-relaxed">Continuous monitoring, adjustments, skills transfer. The organisation becomes autonomous.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 px-4 text-center">
      <p class="text-xl text-navy font-medium italic max-w-2xl mx-auto mb-8">
        "Our role is not to produce a theoretical diagnostic. It is to make real operations legible so that clear decisions can be made."
      </p>
      <a href="/en/contact" class="inline-flex items-center gap-2 bg-teal hover:bg-teal-dark text-white font-bold px-6 py-3 rounded-lg transition-colors">
        Request a 30-min strategic review
      </a>
    </section>

  </main>
  <Footer />
</Base>
