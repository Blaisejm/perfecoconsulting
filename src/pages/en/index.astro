---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="PerfEco Consulting | Business Performance & Digital Transformation in New Caledonia"
  description="PerfEco helps executive teams clarify operations, improve reporting and deliver measurable performance through pragmatic, field-based consulting."
>
  <Nav />

  <main class="pt-16">

    <!-- HERO -->
    <section class="relative text-white overflow-hidden" style="background: linear-gradient(145deg, #1A3A7A 0%, #2E5DB3 50%, #3A6FD4 100%);">
      <div class="absolute bottom-0 left-0 right-0 opacity-20">
        <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,60 C360,120 1080,0 1440,60 L1440,120 L0,120 Z" fill="white"/>
        </svg>
      </div>

      <div class="max-w-5xl mx-auto px-4 py-24 relative lg:grid lg:grid-cols-2 lg:gap-12 lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 border border-white/30 text-white/90 text-xs font-semibold px-4 py-1.5 rounded-full mb-8 uppercase tracking-widest">
            <span class="w-1.5 h-1.5 bg-teal rounded-full animate-pulse"></span>
            New Caledonia &amp; French Polynesia
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black uppercase leading-tight mb-4 tracking-tight">
            Optimise your organisation.<br />
            <span class="text-teal">Decide with confidence.</span>
          </h1>

          <p class="text-lg text-white/80 max-w-2xl mb-10 leading-relaxed">
            PerfEco Consulting helps CEOs, CFOs, COOs and CIOs clarify how their organisation works, strengthen decision-making and improve performance — based on real operations, not theory.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-16">
            <a href="/en/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white font-black px-8 py-4 rounded-xl transition-colors shadow-lg text-base uppercase tracking-wide">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              Request a 30-min strategic review
            </a>
            <a href="/en/approach" class="inline-flex items-center justify-center gap-2 border-2 border-white/40 text-white hover:bg-white/10 font-bold px-8 py-4 rounded-xl transition-colors text-base uppercase tracking-wide">
              Discover our approach
            </a>
          </div>

          <div class="grid grid-cols-3 gap-6 sm:gap-12 border-t border-white/15 pt-10">
            <div>
              <div class="text-2xl sm:text-3xl font-black text-teal">20+ YRS</div>
              <div class="text-white/60 text-sm mt-1">Pacific experience</div>
            </div>
            <div>
              <div class="text-2xl sm:text-3xl font-black text-teal">NC + PF</div>
              <div class="text-white/60 text-sm mt-1">areas of intervention</div>
            </div>
            <div>
              <div class="text-2xl sm:text-3xl font-black text-teal">KPI</div>
              <div class="text-white/60 text-sm mt-1">defined from day one</div>
            </div>
          </div>
        </div>

        <div class="hidden lg:block">
          <img
            src="/photos/jmb-presentation.jpg"
            alt="Jean-Michel Blaise — PerfEco Consulting"
            class="rounded-2xl shadow-2xl object-cover object-top w-full h-[480px]"
          />
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="py-20 px-4 bg-gray-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">What we see in the field</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-navy">
            Teams move forward, but priorities, data<br />
            <span class="text-gray-500 font-normal">and decisions are not always aligned.</span>
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm flex gap-4">
            <span class="text-2xl shrink-0">📊</span>
            <div>
              <h3 class="font-semibold text-navy mb-1">Partial data</h3>
              <p class="text-gray-600 text-sm leading-relaxed">Each department works with its own version of reality.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm flex gap-4">
            <span class="text-2xl shrink-0">⚡</span>
            <div>
              <h3 class="font-semibold text-navy mb-1">Overloaded key people</h3>
              <p class="text-gray-600 text-sm leading-relaxed">The strongest profiles carry too many critical topics.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm flex gap-4">
            <span class="text-2xl shrink-0">💸</span>
            <div>
              <h3 class="font-semibold text-navy mb-1">Hidden costs</h3>
              <p class="text-gray-600 text-sm leading-relaxed">Rework, duplication and delays are not always measured.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm flex gap-4">
            <span class="text-2xl shrink-0">🔄</span>
            <div>
              <h3 class="font-semibold text-navy mb-1">Weak cross-functional processes</h3>
              <p class="text-gray-600 text-sm leading-relaxed">Friction slows down execution and decision-making.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DIFFERENTIATION -->
    <section class="py-20 px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">What sets us apart</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-navy">
            We start from how your organisation really works —<br />
            <span class="font-normal text-gray-500">not from a pre-written solution.</span>
          </h2>
        </div>

        <div class="grid sm:grid-cols-3 gap-8 mb-14">
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-teal/10 text-teal font-bold text-sm flex items-center justify-center mx-auto mb-4">01</div>
            <h3 class="font-bold text-navy text-lg mb-2">See clearly</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Objectively analyse operations, workflows, friction points and available data.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-teal/10 text-teal font-bold text-sm flex items-center justify-center mx-auto mb-4">02</div>
            <h3 class="font-bold text-navy text-lg mb-2">Decide</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Help leadership make choices with a neutral, clear and shareable basis.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-teal/10 text-teal font-bold text-sm flex items-center justify-center mx-auto mb-4">03</div>
            <h3 class="font-bold text-navy text-lg mb-2">Execute</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Turn analysis into concrete, measurable actions that teams can understand and apply.</p>
          </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="bg-navy/5 rounded-lg p-4 text-center">
            <div class="font-semibold text-navy text-sm mb-1">Organisation</div>
            <div class="text-gray-500 text-xs leading-tight">Roles, responsibilities, management lines</div>
          </div>
          <div class="bg-navy/5 rounded-lg p-4 text-center">
            <div class="font-semibold text-navy text-sm mb-1">Processes</div>
            <div class="text-gray-500 text-xs leading-tight">Real workflows, friction, bottlenecks</div>
          </div>
          <div class="bg-navy/5 rounded-lg p-4 text-center">
            <div class="font-semibold text-navy text-sm mb-1">IS &amp; tools</div>
            <div class="text-gray-500 text-xs leading-tight">Real adoption, data quality</div>
          </div>
          <div class="bg-navy/5 rounded-lg p-4 text-center">
            <div class="font-semibold text-navy text-sm mb-1">Reporting</div>
            <div class="text-gray-500 text-xs leading-tight">Concrete KPIs, decision visibility</div>
          </div>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section class="py-20 px-4 bg-navy-dark text-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">What you gain</p>
          <h2 class="text-3xl sm:text-4xl font-bold">Concrete results for leadership teams and operations</h2>
        </div>

        <div class="grid sm:grid-cols-3 gap-6 mb-14">
          <div class="bg-white/5 rounded-xl p-6 text-center">
            <div class="text-teal text-3xl mb-2">📉</div>
            <div class="text-white font-semibold">Less administrative time</div>
          </div>
          <div class="bg-white/5 rounded-xl p-6 text-center">
            <div class="text-teal text-3xl mb-2">🎯</div>
            <div class="text-white font-semibold">More reliable reporting</div>
          </div>
          <div class="bg-white/5 rounded-xl p-6 text-center">
            <div class="text-teal text-3xl mb-2">⚡</div>
            <div class="text-white font-semibold">Faster decision-making</div>
          </div>
          <div class="bg-white/5 rounded-xl p-6 text-center">
            <div class="text-teal text-3xl mb-2">💰</div>
            <div class="text-white font-semibold">Fewer inefficient costs</div>
          </div>
          <div class="bg-white/5 rounded-xl p-6 text-center">
            <div class="text-teal text-3xl mb-2">🤝</div>
            <div class="text-white font-semibold">Better aligned teams</div>
          </div>
          <div class="bg-white/5 rounded-xl p-6 text-center">
            <div class="text-teal text-3xl mb-2">📊</div>
            <div class="text-white font-semibold">Measurable performance</div>
          </div>
        </div>

        <blockquote class="bg-white/5 rounded-2xl p-8 text-center">
          <p class="text-xl italic text-gray-200 leading-relaxed mb-4">
            "Jean-Michel managed complex organisational challenges with tact and method. He demonstrated a strong ability to deliver on time and on budget. I recommend him without reservation."
          </p>
          <footer class="text-teal font-medium">
            Emmanuel Fouché, Director EPI<br />
            <span class="text-gray-400 font-normal text-sm">ENGIE Pacific IT — Noumea, July 2024</span>
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- METHOD -->
    <section class="py-20 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">Our method</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-4">A progressive approach to secure performance</h2>
        <p class="text-gray-500 mb-12">Three structured phases, tailored to your context and priorities.</p>

        <div class="grid sm:grid-cols-3 gap-6">
          <div class="rounded-xl p-8 text-center bg-navy/10 text-navy">
            <div class="text-xs font-bold uppercase tracking-widest mb-3 opacity-70">Phase 1</div>
            <div class="text-xl font-bold mb-2">Targeted review</div>
            <div class="text-sm opacity-70 mb-3">Understand real operations, friction points and priorities.</div>
          </div>
          <div class="rounded-xl p-8 text-center bg-teal/10 text-teal">
            <div class="text-xs font-bold uppercase tracking-widest mb-3 opacity-70">Phase 2</div>
            <div class="text-xl font-bold mb-2">Structuring</div>
            <div class="text-sm opacity-70 mb-3">Clarify processes, roles, indicators and decision rules.</div>
          </div>
          <div class="rounded-xl p-8 text-center bg-navy-dark text-white">
            <div class="text-xs font-bold uppercase tracking-widest mb-3 opacity-70">Phase 3</div>
            <div class="text-xl font-bold mb-2">Support</div>
            <div class="text-sm opacity-70 mb-3">Steer implementation, measure gains and transfer skills.</div>
          </div>
        </div>

        <a href="/en/approach" class="inline-flex items-center gap-2 mt-10 text-teal font-semibold hover:underline">
          Discover the PerfEco approach →
        </a>
      </div>
    </section>

    <!-- FOUNDER -->
    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 sm:p-12 flex flex-col sm:flex-row gap-8 items-start">
          <div class="shrink-0">
            <img src="/photos/jmb-portrait.jpg" alt="Jean-Michel Blaise" class="w-24 h-24 rounded-full object-cover shadow-lg object-[center_15%]" />
          </div>
          <div>
            <h2 class="text-2xl font-bold text-navy mb-1">Jean-Michel Blaise</h2>
            <p class="text-teal font-medium mb-4">Founder, PerfEco Consulting</p>
            <p class="text-gray-600 leading-relaxed mb-4">
              Engineer and MBA graduate with over 20 years of experience in organisation, information systems and operational performance across the Pacific. His background covers complex environments in New Caledonia, French Polynesia and internationally.
            </p>
            <p class="text-gray-600 leading-relaxed mb-6 italic">
              Our belief: performance cannot be imposed. It must be clarified, managed and improved with the teams.
            </p>
            <a href="/en/about" class="text-teal font-semibold hover:underline">Learn more →</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Base>
