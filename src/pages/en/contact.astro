---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Request a strategic review — PerfEco Consulting" description="Request a free 30-minute strategic review with Jean-Michel Blaise, founder of PerfEco Consulting.">
  <Nav />
  <main class="pt-16">

    <section class="bg-navy-dark text-white py-20 px-4">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">Strategic review</p>
        <h1 class="text-4xl font-bold mb-4">Want a clearer view?</h1>
        <p class="text-gray-300 text-lg leading-relaxed">
          In 30 minutes, we identify your main friction points, 2 to 3 concrete improvement opportunities, and a clear view of your real priorities.
        </p>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="max-w-5xl mx-auto grid sm:grid-cols-2 gap-12 items-start">

        <div>
          <h2 class="text-2xl font-bold text-navy mb-6">Send a request</h2>
          <form name="contact-en" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-5">
            <input type="hidden" name="form-name" value="contact-en" />
            <p class="hidden"><label>Do not fill: <input name="bot-field" /></label></p>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="firstname" class="block text-sm font-medium text-gray-700 mb-1">First name *</label>
                <input type="text" id="firstname" name="firstname" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal" />
              </div>
              <div>
                <label for="lastname" class="block text-sm font-medium text-gray-700 mb-1">Last name *</label>
                <input type="text" id="lastname" name="lastname" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal" />
              </div>
            </div>

            <div>
              <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Role *</label>
              <select id="role" name="role" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal bg-white">
                <option value="">Select...</option>
                <option>Chief Executive Officer</option>
                <option>Chief Financial Officer</option>
                <option>Chief Operating Officer</option>
                <option>Chief Information Officer</option>
                <option>Other executive</option>
              </select>
            </div>

            <div>
              <label for="organisation" class="block text-sm font-medium text-gray-700 mb-1">Organisation *</label>
              <input type="text" id="organisation" name="organisation" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal" />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Professional email *</label>
              <input type="email" id="email" name="email" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal" />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal" />
            </div>

            <div>
              <label for="challenge" class="block text-sm font-medium text-gray-700 mb-1">What is your main challenge?</label>
              <textarea id="challenge" name="challenge" rows="4" placeholder="Briefly describe the situation you would like to discuss..." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal resize-none"></textarea>
            </div>

            <button type="submit" class="w-full bg-teal hover:bg-teal-dark text-white font-bold py-3 px-6 rounded-lg transition-colors shadow">
              Send my request
            </button>
            <p class="text-xs text-gray-400 text-center">Confidential discussion · Response within 24h · Led by Jean-Michel</p>
          </form>
        </div>

        <div class="space-y-8">
          <div class="bg-gray-50 rounded-xl p-6">
            <h3 class="font-bold text-navy mb-4">What you will get in 30 minutes</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-gray-700"><span class="text-teal font-bold mt-0.5">✓</span>A clear picture of your organisation</li>
              <li class="flex items-start gap-3 text-sm text-gray-700"><span class="text-teal font-bold mt-0.5">✓</span>2 to 3 concrete improvement opportunities</li>
              <li class="flex items-start gap-3 text-sm text-gray-700"><span class="text-teal font-bold mt-0.5">✓</span>A clear view of your real priorities</li>
              <li class="flex items-start gap-3 text-sm text-gray-700"><span class="text-teal font-bold mt-0.5">✓</span>A discussion led personally by Jean-Michel</li>
            </ul>
          </div>

          <div class="bg-navy-dark text-white rounded-xl p-6">
            <p class="text-sm text-gray-400 italic">
              "Reviews are led personally by Jean-Michel. Slots are intentionally limited to ensure the quality of each discussion."
            </p>
          </div>

          <div class="space-y-3 text-sm">
            <a href="mailto:contact@perfeco.nc" class="flex items-center gap-3 text-gray-600 hover:text-navy">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              contact@perfeco.nc
            </a>
            <a href="tel:+68773087" class="flex items-center gap-3 text-gray-600 hover:text-navy">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              +687 73 08 75
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
