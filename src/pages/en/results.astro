---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Client Results — PerfEco Consulting" description="PerfEco client outcomes: ENGIE Pacific, Vale/Prony Resources, Groupe Dumez. Measurable results in New Caledonia and French Polynesia.">
  <Nav />
  <main class="pt-16">

    <section class="bg-navy-dark text-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">Client results</p>
        <h1 class="text-4xl sm:text-5xl font-bold mb-6">Complex environments, demanding territories</h1>
        <p class="text-gray-300 text-lg">Subsidiaries of international groups, multi-entity structures, local regulatory constraints.</p>
      </div>
    </section>

    <section class="py-16 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-3 gap-6 text-center">
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-3xl sm:text-4xl font-bold text-teal mb-1">–30%</div>
            <div class="font-semibold text-navy text-sm mb-1">Administrative time</div>
            <div class="text-gray-400 text-xs">On key processes</div>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-3xl sm:text-4xl font-bold text-teal mb-1">–25%</div>
            <div class="font-semibold text-navy text-sm mb-1">Inefficient costs</div>
            <div class="text-gray-400 text-xs">Identified and eliminated</div>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-3xl sm:text-4xl font-bold text-teal mb-1">+40%</div>
            <div class="font-semibold text-navy text-sm mb-1">Performance gain</div>
            <div class="text-gray-400 text-xs">Measured by KPI</div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="max-w-5xl mx-auto space-y-10">
        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
          <div class="bg-navy p-6 sm:p-8">
            <div class="mb-4">
              <h2 class="text-xl font-bold text-white">ENGIE Pacific (EPI)</h2>
              <span class="text-teal text-sm font-medium">Energy &amp; IT</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">+35% decision speed</div>
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">–25% reporting errors</div>
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">90% tool adoption in 2 months</div>
            </div>
          </div>
          <div class="p-6 sm:p-8">
            <p class="text-gray-600 mb-4 leading-relaxed"><strong class="text-navy">Context:</strong> Organisational transformation under strong regulatory pressure. Multi-entity environment with complex IT governance challenges.</p>
            <blockquote class="border-l-4 border-teal pl-4 mt-4">
              <p class="text-gray-600 italic">"Jean-Michel managed complex organisational challenges with tact and method. He demonstrated a strong ability to deliver on time and on budget. I recommend him without reservation."</p>
              <footer class="text-gray-400 text-sm mt-2">— Emmanuel Fouché, Director EPI, ENGIE Pacific IT — Noumea, July 2024</footer>
            </blockquote>
          </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
          <div class="bg-navy p-6 sm:p-8">
            <div class="mb-4">
              <h2 class="text-xl font-bold text-white">Vale / Prony Resources</h2>
              <span class="text-teal text-sm font-medium">Mining industry</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">3 months → 5 days</div>
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">+20% reporting accuracy</div>
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">+30% project time saved</div>
            </div>
          </div>
          <div class="p-6 sm:p-8">
            <p class="text-gray-600 leading-relaxed"><strong class="text-navy">Context:</strong> Project management in a complex industrial environment. Multi-level reporting and reduction of processing lead times.</p>
          </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
          <div class="bg-navy p-6 sm:p-8">
            <div class="mb-4">
              <h2 class="text-xl font-bold text-white">Groupe Dumez / VCOM</h2>
              <span class="text-teal text-sm font-medium">Construction &amp; Multi-entity</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">+20% operational time freed</div>
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">+30% productivity gain</div>
              <div class="bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full whitespace-nowrap">40% tool adoption in 3 months</div>
            </div>
          </div>
          <div class="p-6 sm:p-8">
            <p class="text-gray-600 leading-relaxed"><strong class="text-navy">Context:</strong> Structuring and digitalisation of a multi-entity group in transformation. Need for organisational consistency and tool adoption.</p>
          </div>
        </div>
      </div>

      <div class="text-center mt-14">
        <p class="text-gray-500 mb-6">These results were achieved in constrained environments, with lean teams and tight deadlines.</p>
        <a href="/en/contact" class="inline-flex items-center gap-2 bg-teal hover:bg-teal-dark text-white font-bold px-6 py-3.5 rounded-lg transition-colors shadow text-lg">
          Discuss your situation
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Base>
