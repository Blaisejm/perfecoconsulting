---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Legal Notice & Privacy Policy" description="Legal notice, privacy policy and GDPR information for PerfEco Consulting.">
  <Nav />

  <main class="pt-16">
    <section class="bg-navy-dark text-white py-16 px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl font-bold mb-4">Legal Notice</h1>
        <p class="text-gray-300">Privacy Policy & GDPR</p>
      </div>
    </section>

    <section class="py-16 px-4">
      <div class="max-w-3xl mx-auto space-y-12 text-gray-700">

        <!-- Publisher -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-4">1. Publisher</h2>
          <p>The website <strong>perfeco.nc</strong> is published by:</p>
          <ul class="mt-3 space-y-1">
            <li><strong>Company name:</strong> PerfEco Consulting</li>
            <li><strong>Legal form:</strong> Sole proprietorship</li>
            <li><strong>Publication manager:</strong> Jean-Michel Blaise</li>
            <li><strong>Location:</strong> New Caledonia</li>
            <li><strong>Email:</strong> <a href="mailto:contact@perfeco.nc" class="text-teal hover:underline">contact@perfeco.nc</a></li>
            <li><strong>Phone:</strong> +687 73 08 75</li>
          </ul>
        </div>

        <!-- Hosting -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-4">2. Hosting</h2>
          <p>This website is hosted by:</p>
          <ul class="mt-3 space-y-1">
            <li><strong>Company:</strong> Netlify, Inc.</li>
            <li><strong>Address:</strong> 512 2nd Street, Suite 200, San Francisco, CA 94107, United States</li>
            <li><strong>Website:</strong> <a href="https://www.netlify.com" class="text-teal hover:underline" target="_blank">www.netlify.com</a></li>
          </ul>
        </div>

        <!-- Intellectual property -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-4">3. Intellectual Property</h2>
          <p>All content on this website (text, images, logo, graphics) is the exclusive property of PerfEco Consulting and is protected by applicable intellectual property laws. Any reproduction, even partial, is prohibited without prior authorisation.</p>
        </div>

        <!-- Data collection -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-4">4. Personal Data Collection</h2>
          <p class="mb-3">PerfEco Consulting collects personal data in the following cases:</p>

          <h3 class="text-lg font-semibold text-navy mb-2">4.1 Contact Form</h3>
          <p>Data collected (name, email, organisation, message) is used solely to respond to your request. It is not shared with third parties and is retained for a maximum of 3 years.</p>

          <h3 class="text-lg font-semibold text-navy mt-4 mb-2">4.2 Google Analytics</h3>
          <p>This website uses Google Analytics (Google LLC) to measure audience. Cookies may be placed on your device with your consent. Data collected (pages visited, visit duration, approximate geographic origin) is anonymised and cannot identify you personally.</p>
          <p class="mt-2">You can refuse Google Analytics via the consent banner on this website.</p>
        </div>

        <!-- Cookies -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-4">5. Cookies</h2>
          <p class="mb-3">This website uses only analytical cookies (Google Analytics) subject to your prior consent. No advertising or third-party tracking cookies are used.</p>
          <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left p-3 font-semibold text-navy">Cookie</th>
                <th class="text-left p-3 font-semibold text-navy">Purpose</th>
                <th class="text-left p-3 font-semibold text-navy">Duration</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-gray-200">
                <td class="p-3">_ga</td>
                <td class="p-3">Audience measurement (Google Analytics)</td>
                <td class="p-3">2 years</td>
              </tr>
              <tr class="border-t border-gray-200">
                <td class="p-3">_ga_*</td>
                <td class="p-3">Audience measurement (Google Analytics 4)</td>
                <td class="p-3">2 years</td>
              </tr>
              <tr class="border-t border-gray-200">
                <td class="p-3">cookie-consent</td>
                <td class="p-3">Storing your consent choice</td>
                <td class="p-3">1 year</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Rights -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-4">6. Your Rights</h2>
          <p class="mb-3">Under the General Data Protection Regulation (GDPR - EU 2016/679), you have the following rights:</p>
          <ul class="space-y-2 list-disc list-inside">
            <li><strong>Right of access:</strong> obtain a copy of your personal data</li>
            <li><strong>Right of rectification:</strong> correct inaccurate data</li>
            <li><strong>Right to erasure:</strong> request deletion of your data</li>
            <li><strong>Right to object:</strong> object to the processing of your data</li>
            <li><strong>Right to portability:</strong> receive your data in a structured format</li>
          </ul>
          <p class="mt-4">To exercise these rights, contact us at: <a href="mailto:contact@perfeco.nc" class="text-teal hover:underline">contact@perfeco.nc</a></p>
        </div>

        <!-- Data controller -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-4">7. Data Controller</h2>
          <p>The data controller is Jean-Michel Blaise, founder of PerfEco Consulting, reachable at <a href="mailto:contact@perfeco.nc" class="text-teal hover:underline">contact@perfeco.nc</a>.</p>
        </div>

        <!-- Last update -->
        <div class="text-sm text-gray-400 border-t border-gray-200 pt-6">
          <p>Last updated: June 2026</p>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Base>
