---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Diagnostic stratégique 60 min" description="Demandez un diagnostic stratégique confidentiel de 60 minutes avec l'équipe PerfEco Consulting.">
  <Nav />

  <main class="pt-16">
    <section class="bg-navy-dark text-white py-20 px-4">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-teal font-semibold text-sm uppercase tracking-wide mb-3">Diagnostic stratégique</p>
        <h1 class="text-4xl font-bold mb-4">Vous souhaitez reprendre le contrôle&nbsp;?</h1>
        <p class="text-gray-300 text-lg leading-relaxed">
          En 60 minutes, vous repartez avec une lecture claire de votre organisation, 2 à 3 pistes d'amélioration concrètes et une vision de vos priorités réelles.
        </p>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="max-w-5xl mx-auto grid sm:grid-cols-2 gap-12 items-start">

        <!-- Formulaire -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-6">Demander un échange</h2>

          <div id="form-success" style="display:none" class="bg-green-50 border border-green-200 rounded-xl p-6 text-center">
            <p class="text-green-700 font-semibold text-lg mb-2">Message envoyé !</p>
            <p class="text-green-600 text-sm">L'équipe PerfEco vous répondra dans les 48 heures.</p>
          </div>

          <div id="form-error" style="display:none" class="bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
            <p class="text-red-600 text-sm">Une erreur est survenue. Veuillez réessayer ou contacter directement contact@perfeco.nc</p>
          </div>

          <form id="contact-form" class="space-y-5">

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="prenom" class="block text-sm font-medium text-gray-700 mb-1">Prénom *</label>
                <input type="text" id="prenom" name="prenom" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal" />
              </div>
              <div>
                <label for="nom" class="block text-sm font-medium text-gray-700 mb-1">Nom *</label>
                <input type="text" id="nom" name="nom" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal" />
              </div>
            </div>

            <div>
              <label for="fonction" class="block text-sm font-medium text-gray-700 mb-1">Fonction *</label>
              <select id="fonction" name="fonction" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal bg-white">
                <option value="">Sélectionner...</option>
                <option>Directeur Général / PDG</option>
                <option>Directeur Administratif et Financier</option>
                <option>Directeur des Opérations / COO</option>
                <option>Directeur des Systèmes d'Information</option>
                <option>Autre direction</option>
              </select>
            </div>

            <div>
              <label for="organisation" class="block text-sm font-medium text-gray-700 mb-1">Organisation *</label>
              <input type="text" id="organisation" name="organisation" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal" />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email professionnel *</label>
              <input type="email" id="email" name="email" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal" />
            </div>

            <div>
              <label for="telephone" class="block text-sm font-medium text-gray-700 mb-1">Téléphone</label>
              <input type="tel" id="telephone" name="telephone" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal" />
            </div>

            <div>
              <label for="sujet" class="block text-sm font-medium text-gray-700 mb-1">Quel est votre principal enjeu&nbsp;?</label>
              <textarea id="sujet" name="sujet" rows="4" placeholder="Décrivez en quelques lignes la situation que vous souhaitez aborder..." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal focus:border-teal resize-none"></textarea>
            </div>

            <div style="position:absolute;left:-9999px;opacity:0;height:0;overflow:hidden" aria-hidden="true"><label for="website">Ne pas remplir</label><input type="text" id="website" name="website" tabindex="-1" autocomplete="off" /></div><button type="submit" id="submit-btn" class="w-full bg-teal hover:bg-teal-dark text-white font-bold py-3 px-6 rounded-lg transition-colors shadow">
              Envoyer ma demande
            </button>

            <p class="text-xs text-gray-400 text-center">
              Échange confidentiel · Réponse sous 48h · Mené par l'équipe PerfEco
            </p>
          </form>
        </div>

        <!-- Infos -->
        <div class="space-y-8">
          <div class="bg-gray-50 rounded-xl p-6">
            <h3 class="font-bold text-navy mb-4">Ce que vous obtiendrez en 60 min</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-gray-700">
                <span class="text-teal font-bold mt-0.5">✓</span>
                Une lecture claire de votre organisation
              </li>
              <li class="flex items-start gap-3 text-sm text-gray-700">
                <span class="text-teal font-bold mt-0.5">✓</span>
                2 à 3 pistes d'amélioration concrètes
              </li>
              <li class="flex items-start gap-3 text-sm text-gray-700">
                <span class="text-teal font-bold mt-0.5">✓</span>
                Une vision de vos priorités réelles
              </li>
              <li class="flex items-start gap-3 text-sm text-gray-700">
                <span class="text-teal font-bold mt-0.5">✓</span>
                Un échange mené par l'équipe PerfEco
              </li>
            </ul>
          </div>

          <div class="bg-navy-dark text-white rounded-xl p-6">
            <p class="text-sm text-gray-400 italic">
              « Les diagnostics sont menés par l'équipe PerfEco. Les créneaux sont volontairement limités pour garantir la qualité de chaque échange. »
            </p>
          </div>

          <div class="space-y-3 text-sm">
            <a href="mailto:contact@perfeco.nc" class="flex items-center gap-3 text-gray-600 hover:text-navy">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              contact@perfeco.nc
            </a>
            <a href="tel:+68773087" class="flex items-center gap-3 text-gray-600 hover:text-navy">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              +687 73 08 75
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  document.getElementById('contact-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('submit-btn');
    var success = document.getElementById('form-success');
    var error = document.getElementById('form-error');

    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';
    error.style.display = 'none';

    var data = {
      nom: document.getElementById('prenom').value + ' ' + document.getElementById('nom').value,
      email: document.getElementById('email').value,
      organisation: document.getElementById('fonction').value + ' — ' + document.getElementById('organisation').value,
      message: document.getElementById('sujet').value || '(aucun message)'
    };

    try {
      var res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (res.ok) {
        document.getElementById('contact-form').style.display = 'none';
        success.style.display = 'block';
      } else {
        error.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Envoyer ma demande';
      }
    } catch(err) {
      error.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Envoyer ma demande';
    }
  });
</script>
